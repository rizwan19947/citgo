# Copy to .env.local and fill in real values. All vars are server-side only.

# DotCMS instance (required)
DOTCMS_HOST=https://your-dotcms-instance.com
DOTCMS_AUTH_TOKEN=your-dotcms-api-token

# Sites served, numbered from 1 with no gaps: hostname|siteIdentifier|assetSlug
# (site identifier, not inode; assetSlug = folder under public/assets/).
# Keep this list identical on every deployment.
SITE_1=site-one.com|REPLACE_WITH_DOTCMS_SITE_IDENTIFIER|siteone
SITE_2=site-two.com|REPLACE_WITH_DOTCMS_SITE_IDENTIFIER|sitetwo
SITE_3=site-three.com|REPLACE_WITH_DOTCMS_SITE_IDENTIFIER|sitethree

# Fallback when the Host header matches no SITE_n (required)
DEFAULT_SITE_HOST=site-one.com

# Pin this deployment to ONE site — must match a SITE_n hostname.
# Required on per-site production deployments; handy locally too.
# Unset = shared deployment resolving sites by Host header.
FRONTEND_HOST_OVERRIDE=site-one.com

# "development" enables the local assetPrefix (see next.config.ts)
ENVIRONMENT=development|production

# Leave unset — the sites are not indexed (see docs/seo-handover.md)
# SITE_INDEXING=true
